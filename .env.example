# Root-level — read only by `docker compose -f docker-compose.prod.yml` for variable
# substitution (Caddy's domains, the web image's build-time NEXT_PUBLIC_* args).
# Copy to `.env` and fill in. The API's own runtime config lives separately in
# apps/api/.env (see apps/api/.env.example) — this file does not replace that.

# Public domains Caddy issues certificates for and routes traffic to.
DOMAIN_APP=app.yourdomain.com
DOMAIN_API=api.yourdomain.com

# Baked into the web app's client bundle at BUILD time — must be the public HTTPS
# URL the browser will actually call, not localhost.
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=
NEXT_PUBLIC_MICROSOFT_TENANT_ID=
NEXT_PUBLIC_MICROSOFT_REDIRECT_URI=https://app.yourdomain.com/auth/callback

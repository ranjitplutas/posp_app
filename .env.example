# Root-level — read only by `docker compose` (dev) for build-arg variable
# substitution. Copy to `.env` and fill in. The API's own runtime config lives
# separately in apps/api/.env (see apps/api/.env.example) — this file does not
# replace that. For production, see .env.prod.example instead.

# Baked into the web app's client bundle at BUILD time.
# /api/v1 (relative) works because Next.js proxies API calls to the sibling
# Fastify process inside the same container — see apps/web/next.config.js.
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=
NEXT_PUBLIC_MICROSOFT_TENANT_ID=
NEXT_PUBLIC_MICROSOFT_REDIRECT_URI=http://localhost:8082/auth/callback

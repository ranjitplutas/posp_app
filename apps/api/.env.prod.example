# Production API environment variables for Hostinger VPS
# IMPORTANT: Do NOT commit to git! Use .env.prod or manage secrets securely.

NODE_ENV=production
PORT=4000
API_BASE_PATH=/api/v1

# Production database URL (use your actual Hostinger database credentials)
# Example: postgres://user:password@your-db-host.com:5432/prod_digisafe_posp
DATABASE_URL=postgres://postgres:wrecfbbde@115.245.177.14:30013/dev_digisafe_posp
DB_SSL_MODE=require
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000

# Azure App Registration
MICROSOFT_CLIENT_ID=cda4551f-ec13-43cd-a643-31b6e6d2b3e9
MICROSOFT_TENANT_ID=b60a0c65-a3a1-4652-a271-786595256530
MICROSOFT_ALLOWED_TENANT_IDS=b60a0c65-a3a1-4652-a271-786595256530
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/b60a0c65-a3a1-4652-a271-786595256530

APP_JWT_ISSUER=digi-posp-api
APP_JWT_AUDIENCE=digi-posp-web
# IMPORTANT: Generate a NEW secure secret for production!
# node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
APP_JWT_SECRET=iO3N0t8S3E/X2eIvjm3WK63M4xwL0lzjPP7tLfLB45BxxSRAgQmHsz/IMKuMgcbE
APP_JWT_EXPIRES_IN_SECONDS=3600

# Production CORS — same-origin proxy handles browser traffic; this only
# matters for direct API calls (health checks, scripts) from the container itself.
CORS_ALLOWED_ORIGINS=https://pospadmin.digisafe.co.in,http://127.0.0.1:8082
LOG_LEVEL=info
SLOW_QUERY_THRESHOLD_MS=500

# Disable password login in production
ENABLE_PASSWORD_LOGIN=true

# Perfios KYC API
PERFIOS_API_BASE_URL=https://uat-hub.perfios.com

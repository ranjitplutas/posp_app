NODE_ENV=development
PORT=4000
API_BASE_PATH=/api/v1

# Fill in the real connection string manually — never commit real credentials.
DATABASE_URL=postgres://postgres:password@localhost:5432/dev_digisafe_posp
DB_SSL_MODE=disable
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000

# Same Azure App Registration used by posp_app (492cb948-f03f-4860-bb5b-48236ddd655c).
# This app needs its own redirect URI added under Authentication -> Platform: SPA:
#   http://localhost:3000/auth/callback
MICROSOFT_CLIENT_ID=492cb948-f03f-4860-bb5b-48236ddd655c
MICROSOFT_TENANT_ID=b60a0c65-a3a1-4652-a271-786595256530
MICROSOFT_ALLOWED_TENANT_IDS=b60a0c65-a3a1-4652-a271-786595256530
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/b60a0c65-a3a1-4652-a271-786595256530

APP_JWT_ISSUER=digi-posp-api
APP_JWT_AUDIENCE=digi-posp-web
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
APP_JWT_SECRET=
# Also acts as the effective session timeout — the frontend persists the token across page
# refreshes (sessionStorage) and treats this JWT's own expiry as "session timed out".
APP_JWT_EXPIRES_IN_SECONDS=3600

CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info
SLOW_QUERY_THRESHOLD_MS=500

# Local/dev-only username+password login (seed with: npm run seed:local-admin --workspace=apps/api).
# Turn this off (false) once Microsoft SSO works — never intended for production.
ENABLE_PASSWORD_LOGIN=false

# Perfios name-match KYC API — powers the "Validate Name" action on the education
# verification tab. Get the key from Perfios; leave blank to disable (the button
# will show a clear config error instead of the app failing to start).
PERFIOS_API_BASE_URL=https://uat-hub.perfios.com
PERFIOS_API_KEY=
# Score bands (0-100) for the green/orange/red match result badge.
NAME_MATCH_GREEN_THRESHOLD=70
NAME_MATCH_ORANGE_THRESHOLD=50

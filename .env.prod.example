# Production environment variables for Hostinger VPS deployment
# IMPORTANT: Do NOT commit actual credentials to git!
# Copy this to .env.prod and fill in your real values

# Single domain — API and web are one container, proxied under /api/v1.
DOMAIN_APP=app.yourdomain.com

# Next.js public environment variables (baked into the build)
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_MICROSOFT_CLIENT_ID=cda4551f-ec13-43cd-a643-31b6e6d2b3e9
NEXT_PUBLIC_MICROSOFT_TENANT_ID=b60a0c65-a3a1-4652-a271-786595256530
NEXT_PUBLIC_MICROSOFT_REDIRECT_URI=https://app.yourdomain.com/auth/callback
